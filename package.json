{
  "name": "oh-my-skills",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/nextcaicai/oh-my-skills.git"
  },
  "homepage": "https://github.com/nextcaicai/oh-my-skills",
  "bugs": {
    "url": "https://github.com/nextcaicai/oh-my-skills/issues"
  },
  "scripts": {
    "dev": "vite --host localhost --port 1420 --strictPort",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "preview:tauri": "vite preview --host localhost --port 1420 --strictPort",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:dev:hmr": "tauri dev --config src-tauri/tauri.hmr.conf.json",
    "tauri:build": "tauri build",
    "tauri:build:macos": "tauri build --config src-tauri/tauri.macos.conf.json",
    "tauri:build:windows": "tauri build --config src-tauri/tauri.windows.conf.json",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "smoke": "npm run build && npm run test:rust"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.5.0",
    "@tauri-apps/plugin-dialog": "^2.2.2",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.5.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^6.0.5"
  }
}
