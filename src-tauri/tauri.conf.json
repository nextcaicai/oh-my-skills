{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Oh My Skills",
  "version": "0.1.0",
  "identifier": "app.oh-my-skills.desktop",
  "build": {
    "beforeDevCommand": "npm run build && npm run preview:tauri",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Oh My Skills",
        "width": 1280,
        "height": 820,
        "minWidth": 1040,
        "minHeight": 680,
        "transparent": true,
        "backgroundColor": "#00000000",
        "windowEffects": {
          "effects": ["popover"],
          "state": "active"
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": []
  }
}
