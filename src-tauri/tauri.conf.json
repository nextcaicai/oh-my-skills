{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Oh My Skills",
  "version": "0.1.0",
  "identifier": "app.oh-my-skills.desktop",
  "build": {
    "beforeDevCommand": "npm run build && npm run preview:tauri",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Oh My Skills",
        "width": 1080,
        "height": 720,
        "minWidth": 1040,
        "minHeight": 680,
        "transparent": false,
        "titleBarStyle": "Transparent",
        "hiddenTitle": true,
        "backgroundColor": "#F3F4F5"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": ["icons/icon.png"]
  }
}
